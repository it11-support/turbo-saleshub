  unitMsr2   String?   @db.VarChar(255)
  NumPerMsr2 Decimal?  @db.Decimal(18, 4)
  BuyUnitMsr String?   @db.VarChar(255)
  SalUnitMsr String?   @db.VarChar(255)
  NumInSale  Decimal?  @db.Decimal(18, 4)
  NumInBuy   Decimal?  @db.Decimal(18, 4)
